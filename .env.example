# Copy this file to .env and fill in real values before running.

# REQUIRED — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Optional: switch from SQLite to PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/investmap

# Optional: enable real email sending
MAIL_ENABLED=false
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your-smtp-password
# MAIL_FROM=no-reply@investmap.ru
# MAIL_FROM_NAME=InvestMap

# Flask debug mode (keep false in production)
FLASK_DEBUG=false
